---
// Education.astro
const education = [
  {
    degree: "Bachiller Académico (En curso)",
    institution: "Institución Educativa",
    period: "2024 / Actualidad",
    description: "Formación académica básica con un fuerte interés por la tecnología, las ciencias exactas y la programación como bases para el desarrollo profesional futuro."
  }
];
---

<section id="formacion" class="py-20 lg:py-32 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mb-12 text-center md:text-right">Formación Académica</h2>
    
    <div class="space-y-12">
      {education.map((edu) => (
        <div class="relative pl-8 md:pl-0 md:pr-8 border-l-2 md:border-l-0 md:border-r-2 border-blue-200">
          <div class="md:grid md:grid-cols-5 md:gap-8 items-start">
            
            <div class="md:col-span-4 relative md:text-right">
              <!-- Timeline drop desktop -->
              <div class="hidden md:block absolute -right-[21px] top-1.5 h-4 w-4 rounded-full bg-white border-4 border-blue-500 shadow-sm z-10"></div>
              
              <div class="md:hidden text-blue-600 text-sm font-bold mb-1 uppercase tracking-wide -ml-8 px-4 bg-blue-50 inline-block py-1 rounded-r-lg">
                {edu.period}
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-1 mt-2 md:mt-0">{edu.degree}</h3>
              <div class="text-lg text-blue-600 font-semibold mb-4">{edu.institution}</div>
              <p class="text-slate-600 leading-relaxed text-base md:text-lg">
                {edu.description}
              </p>
            </div>

            <div class="hidden md:block md:col-span-1 text-slate-500 text-sm font-bold pt-1 text-left uppercase tracking-wide">
              {edu.period}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
