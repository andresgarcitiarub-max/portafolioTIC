---
// Experience.astro
const experiences = [
  {
    role: "Estudiante enfocado en Tecnología",
    company: "Proyectos Personales",
    period: "Actualidad",
    description: "Desarrollo de proyectos prácticos orientados a resolver problemas reales, integrando hardware electrónico básico y programación de software."
  }
];
---

<section id="experiencia" class="py-20 lg:py-32 bg-slate-50 dark:bg-slate-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-black text-slate-900 dark:text-white mb-12 text-center md:text-left">Experiencia</h2>
    
    <div class="space-y-12">
      {experiences.map((exp) => (
        <div class="relative pl-8 md:pl-0 border-l-2 md:border-l-0 border-blue-200 dark:border-blue-800">
          <div class="md:grid md:grid-cols-5 md:gap-8 items-start">
            <div class="hidden md:block md:col-span-1 text-slate-500 dark:text-slate-400 text-sm font-bold pt-1 text-right uppercase tracking-wide">
              {exp.period}
            </div>
            
            <div class="md:col-span-4 relative">
              <div class="hidden md:block absolute -left-[21px] top-1.5 h-4 w-4 rounded-full bg-white dark:bg-slate-950 border-4 border-blue-500 shadow-sm z-10"></div>
              <div class="hidden md:block absolute -left-4 top-5 bottom-[-3rem] w-0.5 bg-blue-100 dark:bg-blue-900"></div>
              
              <div class="md:hidden text-blue-600 dark:text-blue-400 text-sm font-bold mb-1 uppercase tracking-wide -ml-8 px-4 bg-blue-50 dark:bg-blue-900/30 inline-block py-1 rounded-r-lg">
                {exp.period}
              </div>
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-1 mt-2 md:mt-0">{exp.role}</h3>
              <div class="text-lg text-blue-600 dark:text-blue-400 font-semibold mb-4">{exp.company}</div>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-base md:text-lg">
                {exp.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
