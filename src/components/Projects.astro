---
// Projects.astro
const projects = [
  {
    title: "Detector de personas con celular + micro:bit",
    description: "Sistema que usa la cámara del celular para detectar personas y enviar señales a una micro:bit.",
    tech: ["Python", "Visión por computadora (básico)", "Micro:bit"]
  },
  {
    title: "Sistema interactivo de comparación de fracciones",
    description: "Aplicación que permite comparar fracciones con explicación visual y gráfica.",
    tech: ["HTML", "CSS", "JavaScript"]
  }
];
---

<section id="proyectos" class="py-20 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mb-4">Proyectos</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Selección de aplicaciones prácticas e integraciones de software y hardware.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {projects.map(project => (
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
          <!-- Card Icon/Header -->
          <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6 text-blue-600">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          
          <h3 class="text-2xl font-bold text-slate-900 mb-3">{project.title}</h3>
          <p class="text-slate-600 mb-6 flex-grow text-base md:text-lg leading-relaxed">{project.description}</p>
          
          <div class="flex flex-wrap gap-2 pt-6 border-t border-slate-200">
            {project.tech.map(t => (
              <span class="text-xs font-semibold text-blue-700 bg-blue-100 px-3 py-1 rounded-full">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
